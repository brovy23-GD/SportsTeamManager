<Window x:Class="SportsTeamManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sports Team Manager" Height="550" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- SEARCH BAR -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="SearchTextBox" Width="250" TextChanged="SearchTextBox_TextChanged"/>
        </StackPanel>

        <!-- DATAGRID -->
        <DataGrid x:Name="TeamsDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="TeamsDataGrid_SelectionChanged"
                  CanUserSortColumns="True"
                  Margin="0,0,0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding TeamId}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                <DataGridTextColumn Header="Sport" Binding="{Binding Sport}" Width="*"/>
                <DataGridTextColumn Header="Founded" Binding="{Binding FoundedYear}" Width="80"/>
                <DataGridTextColumn Header="Championships" Binding="{Binding ChampionshipsWon}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- TEAM COUNTER -->
        <TextBlock x:Name="TeamCountTextBlock"
                   Grid.Row="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,5,0,5"
                   FontWeight="Bold"/>

        <!-- INPUT FIELDS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Name"/>
                <TextBox x:Name="NameTextBox" Width="150"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="City"/>
                <TextBox x:Name="CityTextBox" Width="150"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Sport"/>
                <ComboBox x:Name="SportComboBox" Width="150">
                    <ComboBoxItem Content="Baseball"/>
                    <ComboBoxItem Content="Basketball"/>
                    <ComboBoxItem Content="Football"/>
                    <ComboBoxItem Content="Soccer"/>
                    <ComboBoxItem Content="Hockey"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Founded Year"/>
                <TextBox x:Name="FoundedYearTextBox" Width="100"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Championships"/>
                <TextBox x:Name="ChampionshipsTextBox" Width="100"/>
            </StackPanel>

        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button x:Name="AddButton" Content="Add" Width="80" Click="AddButton_Click"/>
            <Button x:Name="UpdateButton" Content="Update" Width="80" Click="UpdateButton_Click"/>
            <Button x:Name="DeleteButton" Content="Delete" Width="80" Click="DeleteButton_Click"/>
            <Button x:Name="ClearButton" Content="Clear" Width="80" Click="ClearButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
